# Конфигурация для build_tags_tx.zsh
# RPC URL для Stellar Public Network
RPC_URL="https://stellar-soroban-public.nodies.app"

# Network Passphrase для Public Network
NETWORK_PASSPHRASE='Public Global Stellar Network ; September 2015'

# Базовая комиссия за операцию (stroops)
BASE_FEE=100

# Максимальная комиссия (если не указана, рассчитывается как BASE_FEE * ops_count)
# MAX_FEE=

# TX_SOURCE: по умолчанию третий адрес из p2.txt (если есть), иначе первый
# TX_SOURCE=GACKTN5DAZGWXRWB2WLM6OPBDHAMT6SJNGLJZPQMEZBUR4JUGBX2UK7V